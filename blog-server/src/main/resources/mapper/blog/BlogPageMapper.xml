<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyiblog.mapper.BlogPageMapper">
    
    <resultMap type="BlogPage" id="BlogPageResult">
        <result property="pageId"    column="page_id"    />
        <result property="title"    column="title"    />
        <result property="slug"    column="slug"    />
        <result property="content"    column="content"    />
        <result property="cover"    column="cover"    />
        <result property="isShow"    column="is_show"    />
        <result property="orderNum"    column="order_num"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectBlogPageVo">
        select page_id, title, slug, content, cover, is_show, order_num, status, create_by, create_time, update_by, update_time, remark from blog_page
    </sql>

    <select id="selectBlogPageList" parameterType="BlogPage" resultMap="BlogPageResult">
        <include refid="selectBlogPageVo"/>
        <where>  
            <if test="title != null  and title != ''"> and title = #{title}</if>
            <if test="slug != null  and slug != ''"> and slug = #{slug}</if>
            <if test="content != null  and content != ''"> and content = #{content}</if>
            <if test="cover != null  and cover != ''"> and cover = #{cover}</if>
            <if test="isShow != null  and isShow != ''"> and is_show = #{isShow}</if>
            <if test="orderNum != null "> and order_num = #{orderNum}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectBlogPageByPageId" parameterType="Long" resultMap="BlogPageResult">
        <include refid="selectBlogPageVo"/>
        where page_id = #{pageId}
    </select>

    <insert id="insertBlogPage" parameterType="BlogPage" useGeneratedKeys="true" keyProperty="pageId">
        insert into blog_page
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">title,</if>
            <if test="slug != null and slug != ''">slug,</if>
            <if test="content != null">content,</if>
            <if test="cover != null">cover,</if>
            <if test="isShow != null">is_show,</if>
            <if test="orderNum != null">order_num,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">#{title},</if>
            <if test="slug != null and slug != ''">#{slug},</if>
            <if test="content != null">#{content},</if>
            <if test="cover != null">#{cover},</if>
            <if test="isShow != null">#{isShow},</if>
            <if test="orderNum != null">#{orderNum},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateBlogPage" parameterType="BlogPage">
        update blog_page
        <trim prefix="SET" suffixOverrides=",">
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="slug != null and slug != ''">slug = #{slug},</if>
            <if test="content != null">content = #{content},</if>
            <if test="cover != null">cover = #{cover},</if>
            <if test="isShow != null">is_show = #{isShow},</if>
            <if test="orderNum != null">order_num = #{orderNum},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where page_id = #{pageId}
    </update>

    <delete id="deleteBlogPageByPageId" parameterType="Long">
        delete from blog_page where page_id = #{pageId}
    </delete>

    <delete id="deleteBlogPageByPageIds" parameterType="String">
        delete from blog_page where page_id in 
        <foreach item="pageId" collection="array" open="(" separator="," close=")">
            #{pageId}
        </foreach>
    </delete>
</mapper>