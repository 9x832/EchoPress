<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyiblog.mapper.BlogArticleTagMapper">
    
    <resultMap type="BlogArticleTag" id="BlogArticleTagResult">
        <result property="articleId"    column="article_id"    />
        <result property="tagId"    column="tag_id"    />
    </resultMap>

    <sql id="selectBlogArticleTagVo">
        select article_id, tag_id from blog_article_tag
    </sql>

    <select id="selectBlogArticleTagList" parameterType="BlogArticleTag" resultMap="BlogArticleTagResult">
        <include refid="selectBlogArticleTagVo"/>
        <where>
            <if test="articleId != null "> and article_id = #{articleId}</if>
            <if test="tagId != null "> and tag_id = #{tagId}</if>
        </where>
    </select>
    
    <select id="selectBlogArticleTagByArticleId" parameterType="Long" resultMap="BlogArticleTagResult">
        <include refid="selectBlogArticleTagVo"/>
        where article_id = #{articleId}
    </select>

    <insert id="insertBlogArticleTag" parameterType="BlogArticleTag">
        insert into blog_article_tag
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="articleId != null">article_id,</if>
            <if test="tagId != null">tag_id,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="articleId != null">#{articleId},</if>
            <if test="tagId != null">#{tagId},</if>
         </trim>
    </insert>

    <update id="updateBlogArticleTag" parameterType="BlogArticleTag">
        update blog_article_tag
        <trim prefix="SET" suffixOverrides=",">
            <if test="tagId != null">tag_id = #{tagId},</if>
        </trim>
        where article_id = #{articleId}
    </update>

    <select id="selectBlogArticleTagByArticleIds" parameterType="Long[]" resultMap="BlogArticleTagResult">
        <include refid="selectBlogArticleTagVo"/>
        where article_id in
        <foreach item="articleId" collection="array" open="(" separator="," close=")">
            #{articleId}
        </foreach>
    </select>

    <insert id="insertBlogArticleTagBatch">
        insert into blog_article_tag (article_id, tag_id) values
        <foreach item="item" collection="list" separator=",">
            (#{item.articleId}, #{item.tagId})
        </foreach>
    </insert>

    <delete id="deleteBlogArticleTagByArticleId" parameterType="Long">
        delete from blog_article_tag where article_id = #{articleId}
    </delete>

    <delete id="deleteBlogArticleTagByArticleIds" parameterType="String">
        delete from blog_article_tag where article_id in 
        <foreach item="articleId" collection="array" open="(" separator="," close=")">
            #{articleId}
        </foreach>
    </delete>
</mapper>